<?xml version="1.0" encoding="UTF-8"?>
<jboss-deployment-structure>
    <deployment>

        <!-- APIs fournies par WildFly -->
        <dependencies>
            <module name="jakarta.enterprise.api"/>
            <module name="jakarta.inject.api"/>
            <module name="jakarta.validation.api"/>
        </dependencies>

        <!-- ✅ FIX: Exclure Hibernate de WildFly car on bundle le nôtre dans le WAR -->
        <exclusions>
            <module name="org.hibernate.orm.core"/>
            <module name="com.mysql"/>
        </exclusions>

    </deployment>
</jboss-deployment-structure>